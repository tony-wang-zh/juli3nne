;;;
; start of one solid block extrusion 
;;;

M950 P0 C"vfd"
M280 P0 S0

M208 U110 S0 ; temperary increase limit 
G1 U50.000 ; move u to initial offset
G91 ; set all axis to relative positioning  

; extrude and z move 
G1 U15.000 F600 ; extrude solid block 

G1 Z-25.000 F1800; move to extrude point, first fast and approach slow
G1 Z-10.000 F200; move to extrude point slowly 7.3 = current print plane + 7.3

; cut
G4 P500 ; hold
M280 P0 S60 ; cut
G4 P1000 ;wait for cut to finish

G1 Z10.000 F200; move back up
G1 Z25.000 F1800; move back up

M280 P0 S0 ; uncut 
G4 P1000 ; wait for uncut to finish

; reset 
G90
M208 U95 S0 ; reset extrusion liimt 
; G28 U ; re-zero U axis
; G1 F1800.000 ; reset speed


G1 X164.788 Y187.8 ; move to dispense point
G1 Z101.5 ; move to dispense point
